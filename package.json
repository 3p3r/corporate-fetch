{
  "name": "corporate-fetch",
  "version": "1.0.0",
  "description": "\"fetch\" designed to run in corporate environments, through your corporate browser!",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "webpack",
    "build:tsc": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "fetch",
    "puppeteer",
    "corporate",
    "proxy",
    "browser"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "debug": "^4.4.1",
    "puppeteer": "^24.20.0",
    "rc": "^1.2.8"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^24.3.1",
    "@types/rc": "^1.2.4",
    "prettier": "^3.6.2",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  }
}
